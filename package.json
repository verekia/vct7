{
  "name": "vct7",
  "version": "0.1.0",
  "private": true,
  "description": "VCT7 — a focused SVG editor for diagonal/parallel/sharp-corner compositions: angle snapping, global bezier rounding, File System API saves.",
  "type": "module",
  "scripts": {
    "dev": "portless vct7 next dev",
    "build": "next build",
    "start": "serve out",
    "postinstall": "next typegen",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "warden": "warden",
    "all": "bun run format:check && bun run lint && bun run typecheck && bun run warden && bun run test"
  },
  "dependencies": {
    "next": "16.2.2",
    "opentype.js": "^1.3.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@tailwindcss/postcss": "4.2.2",
    "@types/bun": "^1.3.0",
    "@types/node": "25.5.2",
    "@types/opentype.js": "^1.3.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@verekia/warden": "0.0.3",
    "babel-plugin-react-compiler": "1.0.0",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "portless": "0.13.0",
    "postcss": "8.5.8",
    "serve": "14.2.6",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2"
  }
}
